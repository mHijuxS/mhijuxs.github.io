{
  "name": "excalidraw-render",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Headless renderer for .excalidraw scenes used in writeups",
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "playwright": "1.48.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "scripts": {
    "bundle": "esbuild entry.js --bundle --format=iife --outfile=public/bundle.js --define:process.env.NODE_ENV=\\\"production\\\" --loader:.woff2=dataurl --loader:.woff=dataurl --loader:.ttf=dataurl --loader:.css=text",
    "render": "node render.mjs"
  }
}
